{
    "version": 2,
    "builds": [
        {
            "src": "api/src/index.ts",
            "use": "@vercel/node"
        },
        {
            "src": "package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api/src/index.ts"
        },
        {
            "src": "/api/health",
            "dest": "/api/src/index.ts"
        },
        {
            "src": "/(.*)",
            "dest": "/dist/$1",
            "check": true
        },
        {
            "src": "/(.*)",
            "dest": "/dist/index.html"
        }
    ]
}
